# Neon: скопіюй з дашборду Neon (Pooled / Direct).
# DATABASE_URL — зазвичай pooled (PgBouncer), для Prisma + serverless.
# DIRECT_URL — direct connection (міграції: prisma migrate deploy / migrate dev).
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

OPENAI_API_KEY=

# Опційно: свій «перець» для 6-значного коду (якщо не задано — на проді береться стабільний варіант з DATABASE_URL)
AUTH_PIN_PEPPER=

# Публічна URL сайту (для Open Graph / metadata); на Vercel можна задати https://your-domain.vercel.app
# NEXT_PUBLIC_SITE_URL=
