{
  "name": "Life Achievement Game",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-20-bookworm",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Next.js",
      "onAutoForward": "notify"
    }
  },
  "remoteEnv": {
    "DATABASE_URL": "file:./dev.db"
  },
  "postCreateCommand": "npm install && npx prisma generate && (npx prisma migrate deploy || true)",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "Prisma.prisma"
      ],
      "settings": {
        "editor.formatOnSave": true
      }
    }
  }
}
