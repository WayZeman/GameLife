{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Next.js: сервер розробки",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "DATABASE_URL": "file:./dev.db"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "Prisma: застосувати міграції",
      "type": "shell",
      "command": "npx prisma migrate deploy",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "DATABASE_URL": "file:./dev.db"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Docker: запуск compose",
      "type": "shell",
      "command": "docker compose up --build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
